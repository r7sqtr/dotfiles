{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Task",
      "Skill",
      "WebSearch",
      "Bash(cd *)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(chmod:*)",
      "Bash(mkdir:*)",
      "mcp__plugin_serena_serena__*",
      "Bash(du:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(python3:*)",
      "Bash(jq:*)",
      "Bash(done)",
      "Bash(xargs cat:*)",
      "Bash(bash:*)",
      "Bash(ls:*)",
      "Bash(env:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(claude:*)",
      "Bash(node:*)",
      "Bash(zsh:*)",
      "Bash(pip:*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/blocked-commands.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vvsaito/.claude/scripts/cc-dashboard-ingest.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vvsaito/.claude/scripts/cc-dashboard-ingest.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline-command.sh"
  },
  "enabledPlugins": {
    "php-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "language": "日本語",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "gist.github.com",
        "api.github.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "packagist.org",
        "repo.packagist.org",
        "mcp.notion.com",
        "api.notion.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "//tmp"
      ],
      "denyRead": [
        "~/.aws/credentials",
        "~/.ssh/id_*",
        "~/.config/gh/hosts.yml",
        "~/.docker/config.json",
        "**/.env*",
        "~/.composer/auth.json"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "tui": "fullscreen",
  "skipAutoPermissionPrompt": true
}
