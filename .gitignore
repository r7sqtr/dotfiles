!claude/scripts/
!claude/scripts/**
!claude/docs/
!claude/docs/**
!claude/skills/
!claude/skills/**

# .gitignore 自体と README も追跡
!.gitignore
!README.md

# nvim 内で無視するファイル
nvim/lazyvim.json
nvim/lazy-lock.json
